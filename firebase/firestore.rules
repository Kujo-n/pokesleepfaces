rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if user is an admin
    // 管理者のFirebase Auth UIDをここに追加する
    function isAdmin() {
      return isAuthenticated() && request.auth.uid in [
        "qiUc5eOanjZyssnFlBwnnu5GMS63"
      ];
    }

    // Pokemon Master Data (公開読み取り, 管理者のみ書き込み)
    match /master/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Staging Master Data
    match /master_staging/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Pokemon Master Data (Read-only for authenticated users, Write denied for client)
    match /pokemon/{pokemonId} {
      allow read: if true; // Public read for now, or restrict to isAuthenticated()
      allow write: if false; // Admin only (via Console or Admin SDK)
    }

    // User Collections
    match /users/{userId}/collections/{pokemonId} {
      allow read, write: if isOwner(userId);
    }
    
    // User Progress/Metadata (if needed)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User Preferences
    match /users/{userId}/preferences/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Staging Environment - User Collections
    match /users_staging/{userId}/collections/{pokemonId} {
      allow read, write: if isOwner(userId);
    }
    
    // Staging Environment - User Progress/Metadata
    match /users_staging/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Staging Environment - User Preferences
    match /users_staging/{userId}/preferences/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
